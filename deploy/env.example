# Copie para .env na mesma pasta (deploy/.env):
#   copy env.example .env
#
# Porta publica do Nginx (mapeada no host)
STACK_HTTP_PORT=8088

# MySQL (Portal)
MYSQL_ROOT_PASSWORD=root_local
MYSQL_PORTAL_PASSWORD=portal_local

# Postgres (Tracking)
POSTGRES_PASSWORD=tracking_local
TRACKING_DATABASE_URL=postgresql://tracking:tracking_local@postgres:5432/tracking

# URLs que o navegador usa (links entre sistemas). Inclua a porta do STACK_HTTP_PORT.
TRACKING_PUBLIC_URL=http://tracking.wct.local:8088/admin/dashboard
PORTAL_WCT_PUBLIC=http://portal.wct.local:8088/portal_wct/index.php
