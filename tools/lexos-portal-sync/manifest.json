{
  "manifest_version": 3,
  "name": "Portal WCT - Lexos Hub",
  "version": "1.2.2",
  "description": "Conector Lexos Hub para o Portal WCT — sincronização automática (TI).",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://app-hub.lexos.com.br/*",
    "https://app-hub-webapi.lexos.com.br/*",
    "https://lexos.metabaseapp.com/*",
    "http://localhost/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app-hub.lexos.com.br/*"],
      "js": ["content-hub.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.onrender.com/*"
      ],
      "js": ["content-portal.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
